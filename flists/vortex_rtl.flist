# Vortex RTL Compilation File List
# Compilation order is critical - base packages first, then interfaces, then implementations

# ============================================================================
# 1. CONFIGURATION AND DEFINE FILES
# ============================================================================
+incdir+$VORTEX_HOME/hw/rtl
+incdir+$VORTEX_HOME/hw/dpi
+incdir+$VORTEX_HOME/hw/rtl/fpu
+incdir+$VORTEX_HOME/hw/rtl/tcu
+incdir+$VORTEX_HOME/hw/rtl/cache
+incdir+$VORTEX_HOME/hw/rtl/mem
+incdir+$VORTEX_HOME/hw/rtl/core
+incdir+$VORTEX_HOME/hw/rtl/libs
+incdir+$VORTEX_HOME/hw/rtl/interfaces
+incdir+$VORTEX_HOME/third_party/hardfloat/source
+incdir+$VORTEX_HOME/hw/rtl/tcu/bhf

+define+SIMULATION
+define+USE_AXI_WRAPPER
+define+EXT_F_ENABLE=1
+define+EXT_D_ENABLE=1
+define+EXT_M_ENABLE=1
+define+EXT_TCU_ENABLE=1

# Configuration headers
$VORTEX_HOME/hw/rtl/VX_config.vh
$VORTEX_HOME/hw/rtl/VX_define.vh
$VORTEX_HOME/hw/rtl/VX_platform.vh
$VORTEX_HOME/hw/rtl/VX_types.vh
$VORTEX_HOME/hw/rtl/VX_scope.vh

# Main GPU package
$VORTEX_HOME/hw/rtl/VX_gpu_pkg.sv

# #CREATED AND ADDED TO SOLVE QUESTASIM 21 DPI ISSUE
#$VORTEX_HOME/hw/rtl/fpu/VX_fpu_dpi_wrapper_pkg.sv

# ============================================================================
# 3. PACKAGES
# ============================================================================

# Subsystem packages
$VORTEX_HOME/hw/rtl/tcu/VX_tcu_pkg.sv
$VORTEX_HOME/hw/rtl/fpu/VX_fpu_pkg.sv


$VORTEX_HOME/hw/rtl/VX_trace_pkg.sv
$VORTEX_HOME/hw/rtl/cache/VX_cache_define.vh
$VORTEX_HOME/hw/rtl/fpu/VX_fpu_define.vh


# ============================================================================
# 2. DPI FILES
# ============================================================================
